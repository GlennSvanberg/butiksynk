# --- Vercel / local Vite (expose to browser; prefix required by Vite) ---
# Production Convex HTTPS URL from https://dashboard.convex.dev
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# --- Convex dashboard only (Settings → Environment variables for prod deployment) ---
# Must match the public origin of this app (e.g. https://your-app.vercel.app).
# Used by convex/auth.config.ts (CONVEX_SITE_URL).
# CONVEX_SITE_URL=https://your-app.vercel.app
