    "@tanstack/react-start": "^1.167.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.35.1",
    "exif-parser": "^0.1.12",
    "jimp": "^1.6.1",
    "lucide-react": "^1.9.0",
    "openai": "^4.85.1",
